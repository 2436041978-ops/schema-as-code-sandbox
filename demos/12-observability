<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>12 与可观测平台的关系 — LoongSuite GenAI SemConv × Schema-As-Code</title>
    <style>
        :root {
            --runtime: #1565c0;
            --runtime-bg: #e3f2fd;
            --design: #ef6c00;
            --design-bg: #fff3e0;
            --bridge: #4caf50;
            --bridge-bg: #e8f5e9;
            --text: #1a1a2e;
            --text-secondary: #666;
            --border: #e0e6ed;
            --radius: 8px;
            --shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: #f5f7fa;
            color: var(--text);
            line-height: 1.6;
            padding: 24px;
        }
        .container { max-width: 1200px; margin: 0 auto; }
        
        /* Header */
        .back {
            display: inline-block;
            margin-bottom: 16px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 13px;
        }
        .back:hover { color: var(--text); }
        
        h1 {
            font-size: 22px;
            margin-bottom: 8px;
            color: var(--text);
        }
        .subtitle {
            font-size: 14px;
            color: var(--text-secondary);
            margin-bottom: 24px;
        }
        
        /* Stage Matrix */
        .matrix {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }
        .stage-card {
            background: white;
            border: 2px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            position: relative;
            overflow: hidden;
        }
        .stage-card.runtime { border-color: var(--runtime); }
        .stage-card.design { border-color: var(--design); }
        
        .stage-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            font-size: 11px;
            font-weight: bold;
            padding: 4px 10px;
            border-radius: 20px;
        }
        .stage-badge.runtime { background: var(--runtime-bg); color: var(--runtime); }
        .stage-badge.design { background: var(--design-bg); color: var(--design); }
        
        .stage-card h3 {
            font-size: 16px;
            margin-bottom: 12px;
            margin-top: 8px;
        }
        .stage-card.runtime h3 { color: var(--runtime); }
        .stage-card.design h3 { color: var(--design); }
        
        .stage-card ul {
            font-size: 13px;
            color: var(--text-secondary);
            padding-left: 18px;
        }
        .stage-card li { margin-bottom: 6px; }
        
        /* Complement Arrow */
        .complement {
            text-align: center;
            padding: 12px;
            font-size: 13px;
            color: var(--text-secondary);
            background: white;
            border-radius: var(--radius);
            border: 1px dashed var(--border);
            margin-bottom: 24px;
        }
        .complement strong { color: var(--bridge); }
        
        /* Demo Area */
        .demo-area {
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
        }
        .demo-title {
            font-size: 14px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-secondary);
            margin-bottom: 20px;
            text-align: center;
        }
        
        /* Three Columns */
        .pipeline {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 16px;
            margin-bottom: 20px;
        }
        
        .pipe-panel {
            background: #fafafa;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px;
            position: relative;
            transition: all 0.3s;
        }
        .pipe-panel.active {
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            transform: translateY(-2px);
        }
        .pipe-panel.active.runtime { border-color: var(--runtime); background: var(--runtime-bg); }
        .pipe-panel.active.design { border-color: var(--design); background: var(--design-bg); }
        .pipe-panel.active.bridge { border-color: var(--bridge); background: var(--bridge-bg); }
        
        .pipe-header {
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .pipe-header.runtime { color: var(--runtime); }
        .pipe-header.design { color: var(--design); }
        .pipe-header.bridge { color: var(--bridge); }
        
        .pipe-content {
            font-size: 12px;
            line-height: 1.6;
        }
        .pipe-content pre {
            background: #1a1a2e;
            color: #a6e22e;
            padding: 10px;
            border-radius: 4px;
            font-size: 11px;
            overflow-x: auto;
            margin-top: 8px;
        }
        .pipe-content .highlight {
            color: #f92672;
            font-weight: bold;
        }
        .pipe-content .success {
            color: #a6e22e;
            font-weight: bold;
        }
        
        /* Connector Arrows */
        .connector {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 40px;
            margin: 12px 0;
            font-size: 12px;
            color: var(--text-secondary);
        }
        .arrow-down {
            text-align: center;
        }
        .arrow-down .line {
            font-size: 20px;
            color: var(--bridge);
        }
        
        /* Controls */
        .controls {
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid var(--border);
        }
        .controls button {
            padding: 10px 24px;
            margin: 0 8px;
            border: none;
            border-radius: var(--radius);
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        }
        .btn-play {
            background: var(--bridge);
            color: white;
        }
        .btn-play:hover { background: #388e3c; }
        .btn-reset {
            background: var(--text-secondary);
            color: white;
        }
        .btn-reset:hover { background: #444; }
        
        /* Log */
        .log {
            background: #1a1a2e;
            border-radius: var(--radius);
            padding: 12px;
            margin-top: 16px;
            max-height: 160px;
            overflow-y: auto;
        }
        .log-title {
            color: #666;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
            border-bottom: 1px solid #333;
            padding-bottom: 4px;
        }
        .log-line {
            font-family: "SF Mono", Monaco, monospace;
            font-size: 12px;
            line-height: 1.8;
            color: #a6e22e;
            padding-left: 8px;
            border-left: 2px solid transparent;
        }
        .log-line.info { color: #66d9ef; }
        .log-line.process { color: #fd971f; }
        .log-line.success { color: #a6e22e; border-left-color: var(--bridge); }
        .log-line.highlight { color: #e6db74; }
        
        /* Value Formula */
        .formula {
            background: linear-gradient(135deg, #f5f7fa 0%, #e8f5e9 100%);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px;
            margin-top: 20px;
            text-align: center;
            font-size: 13px;
            color: var(--text-secondary);
        }
        .formula strong {
            color: var(--bridge);
            font-size: 14px;
        }
        
        @media (max-width: 768px) {
            .pipeline { grid-template-columns: 1fr; }
            .matrix { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="container">
        <a class="back" href="../../">← 返回沙盘首页</a>
        
        <h1>12 与可观测平台的关系</h1>
        <div class="subtitle">
            LoongSuite GenAI SemConv（运行时观测） × Schema-As-Code（设计时约束）的阶段互补与闭环咬合
        </div>
        
        <!-- Stage Complement Matrix -->
        <div class="matrix">
            <div class="stage-card runtime">
                <div class="stage-badge runtime">运行时</div>
                <h3>LoongSuite GenAI SemConv</h3>
                <ul>
                    <li><strong>时机：</strong>漂移发生后（事后）</li>
                    <li><strong>问题：</strong>"漂移发生了吗？"</li>
                    <li><strong>手段：</strong>采集、追踪、分析</li>
                    <li><strong>产出：</strong>Trace / Metric / Token 级观测</li>
                    <li><strong>消费方：</strong>SRE、运维、算法工程师</li>
                </ul>
            </div>
            <div class="stage-card design">
                <div class="stage-badge design">设计时</div>
                <h3>Schema-As-Code</h3>
                <ul>
                    <li><strong>时机：</strong>漂移发生前（事前）</li>
                    <li><strong>问题：</strong>"漂移应该被允许吗？"</li>
                    <li><strong>手段：</strong>约束、校验、拦截</li>
                    <li><strong>产出：</strong>Intent Protocol / Constraint Artifact</li>
                    <li><strong>消费方：</strong>设计师、前端、AI 工程师</li>
                </ul>
            </div>
        </div>
        
        <div class="complement">
            <strong>闭环咬合：</strong>运行时观测发现的漂移案例 → Bridge 归因分析 → 自动创建 PR 收紧设计时规则 → 下一周期验证拦截率
        </div>
        
        <!-- Interactive Demo -->
        <div class="demo-area">
            <div class="demo-title">交互演示：观测 → 归因 → 约束 → 验证</div>
            
            <div class="pipeline">
                <!-- Left: Runtime Observation -->
                <div class="pipe-panel" id="panel-runtime">
                    <div class="pipe-header runtime">
                        <span>👁️</span> 运行时观测（LoongSuite）
                    </div>
                    <div class="pipe-content">
                        <div>Span 类型：<code>invoke_skill</code></div>
                        <div>Skill：<code>alert_card_generation</code></div>
                        <pre id="runtime-trace">{
  "gen_ai.response.text": "严重故障",
  "gen_ai.usage.output_tokens": 42,
  "llm.temperature": 0.85
}</pre>
                        <div style="margin-top:8px;color:#666;">状态：<span id="runtime-status">观测中...</span></div>
                    </div>
                </div>
                
                <!-- Middle: Bridge Attribution -->
                <div class="pipe-panel" id="panel-bridge">
                    <div class="pipe-header bridge">
                        <span>⚡</span> Bridge 归因分析
                    </div>
                    <div class="pipe-content">
                        <div>漂移类型：<span class="highlight">同义词替代</span></div>
                        <div>根因定位：</div>
                        <pre id="bridge-analysis">{
  "drift_type": "synonym_substitution",
  "original_token": "status.critical",
  "llm_output": "严重",
  "root_cause": "temperature > 0.8",
  "confidence": 0.92
}</pre>
                        <div style="margin-top:8px;">动作：<span id="bridge-action">归因中...</span></div>
                    </div>
                </div>
                
                <!-- Right: Design-time Tightening -->
                <div class="pipe-panel" id="panel-design">
                    <div class="pipe-header design">
                        <span>🔒</span> 设计时约束收紧
                    </div>
                    <div class="pipe-content">
                        <div>自动 PR：<code>[Auto] 收紧"严重"同义词规则</code></div>
                        <pre id="design-pr">synonym_mapping:
  - term: "严重"
    standard_token: "critical"
-   confidence_threshold: 0.95
+   confidence_threshold: 0.60
+   prohibited_contexts: ["AW-001"]</pre>
                        <div style="margin-top:8px;">状态：<span id="design-status">等待合并...</span></div>
                    </div>
                </div>
            </div>
            
            <!-- Bottom: Validation Result -->
            <div class="connector arrow-down">
                <div class="line">▼</div>
            </div>
            
            <div class="pipe-panel" id="panel-validation" style="background:#fafafa;">
                <div class="pipe-header" style="color: var(--text-secondary);">
                    <span>✅</span> 下一周期验证：新规则拦截效果
                </div>
                <div class="pipe-content" style="display:flex;gap:20px;align-items:center;">
                    <div style="flex:1;">
                        <div>LLM 再次输出：<code>"严重"</code></div>
                        <div>Validator 推演：<span id="val-result" style="color:#666;">待验证</span></div>
                    </div>
                    <div style="flex:1;">
                        <pre id="val-detail" style="margin:0;">{
  "tier": "semantic",
  "action": "BLOCK",
  "rule": "SEM-001",
  "message": "Value 严重 被 tightened 规则拦截"
}</pre>
                    </div>
                </div>
            </div>
            
            <!-- Controls -->
            <div class="controls">
                <button class="btn-play" onclick="demo.start()">▶ 启动闭环演示</button>
                <button class="btn-reset" onclick="demo.reset()">↺ 重置</button>
            </div>
            
            <!-- Log -->
            <div class="log">
                <div class="log-title">执行日志</div>
                <div id="log-content">
                    <div class="log-line info">就绪。点击"启动闭环演示"观测运行时漂移如何驱动设计时规则迭代。</div>
                </div>
            </div>
            
            <!-- Value Formula -->
            <div class="formula">
                <strong>价值公式：</strong>运行时观测成本 + 设计时约束成本 ＜ 漂移修复成本 + 舆情处理成本
            </div>
        </div>
    </div>
    
    <script>
        const demo = {
            panels: ['panel-runtime', 'panel-bridge', 'panel-design', 'panel-validation'],
            
            log(msg, type = 'info') {
                const panel = document.getElementById('log-content');
                const line = document.createElement('div');
                line.className = `log-line ${type}`;
                line.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
                panel.appendChild(line);
                panel.scrollTop = panel.scrollHeight;
            },
            
            reset() {
                this.panels.forEach(id => {
                    document.getElementById(id).classList.remove('active', 'runtime', 'design', 'bridge');
                });
                document.getElementById('runtime-status').textContent = '观测中...';
                document.getElementById('runtime-status').style.color = '#666';
                document.getElementById('bridge-action').textContent = '归因中...';
                document.getElementById('bridge-action').style.color = '#666';
                document.getElementById('design-status').textContent = '等待合并...';
                document.getElementById('design-status').style.color = '#666';
                document.getElementById('val-result').textContent = '待验证';
                document.getElementById('val-result').style.color = '#666';
                
                document.getElementById('log-content').innerHTML = '<div class="log-line info">就绪。点击"启动闭环演示"观测运行时漂移如何驱动设计时规则迭代。</div>';
            },
            
            async start() {
                this.reset();
                this.log('🚀 启动观测 → 归因 → 约束 → 验证闭环', 'info');
                
                // Step 1: Runtime detects drift
                document.getElementById('panel-runtime').classList.add('active', 'runtime');
                document.getElementById('runtime-status').textContent = '发现漂移：同义词替代';
                document.getElementById('runtime-status').style.color = '#d32f2f';
                this.log('👁️ [LoongSuite] 观测到 Span：gen_ai.response.text = "严重"（应为 status.critical）', 'process');
                await this.sleep(1200);
                
                // Step 2: Bridge attributes
                document.getElementById('panel-bridge').classList.add('active', 'bridge');
                document.getElementById('bridge-action').textContent = '创建自动 PR';
                document.getElementById('bridge-action').style.color = '#4caf50';
                this.log('⚡ [Bridge] 归因完成：temperature=0.85 > 0.8 阈值，同义词替代概率上升', 'success');
                this.log('⚡ [Bridge] 自动 PR：收紧 synonym-mapping.yaml，降低 "严重" 置信度阈值', 'success');
                await this.sleep(1200);
                
                // Step 3: Design-time rule merged
                document.getElementById('panel-design').classList.add('active', 'design');
                document.getElementById('design-status').textContent = '已合并，Compiler 重新编译';
                document.getElementById('design-status').style.color = '#4caf50';
                this.log('🔒 [Schema-As-Code] PR 合并：confidence_threshold 从 0.95 降至 0.60', 'success');
                this.log('🔒 [Compiler] 重新编译产物，分发到 Validator / Runtime', 'success');
                await this.sleep(1200);
                
                // Step 4: Validation in next cycle
                document.getElementById('panel-validation').classList.add('active', 'bridge');
                document.getElementById('val-result').textContent = 'BLOCK — 新规则拦截成功';
                document.getElementById('val-result').style.color = '#4caf50';
                this.log('✅ [Validator] 下一周期：LLM 输出 "严重" → 命中 tightened 规则 → 语义推演 BLOCK', 'highlight');
                this.log('🎉 闭环完成：观测数据驱动规则迭代，拦截率提升', 'highlight');
                
                await this.sleep(500);
                this.panels.forEach(id => document.getElementById(id).classList.remove('active', 'runtime', 'design', 'bridge'));
            },
            
            sleep(ms) {
                return new Promise(resolve => setTimeout(resolve, ms));
            }
        };
    </script>
</body>
</html>
